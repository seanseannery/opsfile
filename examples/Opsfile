# Variables — prefix with environment name to scope to a specific environment
prod_AWS_ACCOUNT=123456789012
preprod_AWS_ACCOUNT=987654321098

prod_AWS_REGION=us-east-1
preprod_AWS_REGION=us-west-2

prod_LOG_GROUP=/aws/ecs/my-service
preprod_LOG_GROUP=/aws/ecs/my-service-preprod

prod_CLUSTER=my-service-prod
preprod_CLUSTER=my-service-preprod


# Shell environment variables can also be referenced with $(VAR_NAME).
# They are injected automatically — no declaration needed in the Opsfile.
# Resolution priority (highest to lowest):
#   1. Opsfile env-scoped   (e.g. prod_VAR=...)
#   2. Shell env-scoped     (e.g. export prod_VAR=... in your terminal)
#   3. Opsfile unscoped     (e.g. VAR=...)
#   4. Shell unscoped       (e.g. export VAR=... in your terminal)
#
# Example: AWS_PROFILE is not defined in this Opsfile, so ops reads it
# from your shell session at runtime.
show-profile:
    default:
        echo "Using AWS profile: $(AWS_PROFILE)"


# Tail CloudWatch logs.
# The default command works for both prod and preprod (variables handle the difference).
# Local overrides to use docker instead.
tail-logs:
    default:
        aws logs tail $(LOG_GROUP) \
            --follow \
            --since 10m \
            --region $(AWS_REGION)

    local:
        docker logs my-service --follow --tail 100


# List the private IPs of running instances.
# prod queries EC2 instances; preprod queries ECS task network interfaces.
list-instance-ips:
    prod:
        aws ec2 describe-instances \
            --filters "Name=instance-state-name,Values=running" \
            --query "Reservations[*].Instances[*].PrivateIpAddress" \
            --output table \
            --region $(AWS_REGION)

    preprod:
        aws ecs list-tasks \
            --cluster $(CLUSTER) \
            --region $(AWS_REGION) \
            --query "taskArns" \
            --output text
