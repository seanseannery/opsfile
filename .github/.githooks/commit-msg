#!/usr/bin/env bash
set -euo pipefail

commit_msg=$(cat "$1")

# Conventional commit pattern:
# <type>(<optional scope>): <description>
# Types: feat, fix, docs, refactor, test, chore, ci, perf, build, revert
pattern='^(feat|fix|docs|refactor|test|chore|ci|perf|build|revert)(\([a-zA-Z0-9_-]+\))?: .+'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "  ERROR: commit message does not follow Conventional Commits format."
  echo ""
  echo "  Expected: <type>: <description>"
  echo "  Example:  feat: add support for env variables"
  echo ""
  echo "  Allowed types: feat, fix, docs, refactor, test, chore, ci, perf, build, revert"
  echo ""
  exit 1
fi

# Check if branch is behind origin/main to avoid conflicts
if git fetch origin main --quiet 2>/dev/null; then
  behind_count=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo "0")
  if [ "$behind_count" -gt 0 ]; then
    echo "  ERROR: your branch is $behind_count commit(s) behind origin/main."
    echo ""
    echo "  Rebase before committing to avoid conflicts:"
    echo ""
    echo "    git pull --rebase origin main"
    echo ""
    exit 1
  fi
fi
